<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record model="ir.module.category" id="module_tasks_manager">
        <field name="name">Task Manager</field>
        <field name="sequence">45</field>
    </record>

    <record id="module_task_manager_privilege" model="res.groups.privilege">
        <field name="name">Custom Task</field>
        <field name="description">Manage tasks</field>
        <field name="category_id" ref="module_tasks_manager"/>
        <field name="sequence">50</field>
    </record>

    <record id="group_team_member" model="res.groups">
        <field name="name">Team Member</field>
        <field name="privilege_id" ref="module_task_manager_privilege"/>
        <field name="comment">Can process tasks but cannot delete</field>
    </record>

    <record id="group_team_lead" model="res.groups">
        <field name="name">Team Lead</field>
        <field name="privilege_id" ref="module_task_manager_privilege"/>
        <field name="implied_ids" eval="[(4, ref('group_team_member'))]"/>
        <field name="comment">Has all permissions for tasks</field>
    </record>

    <record id="task_manager_see_all" model="ir.rule">
        <field name="name">All Tasks</field>
        <field name="model_id" ref="model_task_task"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('custom_task_manager.group_team_lead'))]"/>
    </record>

    <record id="task_manager_see_own" model="ir.rule">
        <field name="name">OWN Tasks</field>
        <field name="model_id" ref="model_task_task"/>
        <field name="domain_force">[('user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('custom_task_manager.group_team_member'))]"/>

        <field name="perm_read" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
